DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optional: email provider for password-reset links (Resend).
# If RESEND_API_KEY is unset, the reset link is logged to the server console
# instead of being emailed — the flow still works, you just read it from the logs.
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
